# ============================================================
# Variáveis de ambiente para o backend no Railway
# Copie este arquivo, preencha os valores e configure no
# painel do Railway em: Variables → Raw Editor
# ============================================================

# --- Banco de dados (Neon) ---
# Copie a connection string do painel do Neon e desmembre abaixo
DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=formflow_db
DB_USER=formflow_user
DB_PASS=SENHA_DO_NEON

# --- JWT ---
# Gere com: openssl rand -base64 64
JWT_SECRET=CHAVE_SECRETA_MINIMO_256_BITS_GERE_COM_OPENSSL

# --- Armazenamento (Cloudflare R2) ---
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
MINIO_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=R2_ACCESS_KEY_ID
MINIO_SECRET_KEY=R2_SECRET_ACCESS_KEY
MINIO_BUCKET_UPLOADS=formflow-uploads
MINIO_BUCKET_PUBLIC=formflow-public

# --- E-mail (Mailtrap ou qualquer SMTP) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=SEU_USERNAME_MAILTRAP
MAIL_PASSWORD=SUA_SENHA_MAILTRAP
MAIL_FROM=noreply@formflow.com
MAIL_FROM_NAME=FormFlow

# --- Frontend (URL do Vercel após deploy) ---
FRONTEND_URL=https://SEU_PROJETO.vercel.app

# --- Opcional: ajustes de performance ---
RATE_LIMIT_ENABLED=true
CLEANUP_ENABLED=true
